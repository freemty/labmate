#!/bin/bash
# Hook: UserPromptSubmit — detect arxiv links and suggest /read-paper
INPUT=$(cat)

# Extract user prompt text
PROMPT=$(echo "$INPUT" | jq -r '.user_prompt // empty' 2>/dev/null)
if [ -z "$PROMPT" ]; then exit 0; fi

# Check for arxiv URL patterns
if ! echo "$PROMPT" | grep -qiE 'arxiv\.org/(abs|pdf|html)/[0-9]+\.[0-9]+'; then exit 0; fi

# Extract the arxiv ID for display
ARXIV_ID=$(echo "$PROMPT" | grep -oiE 'arxiv\.org/(abs|pdf|html)/[0-9]+\.[0-9]+' | head -1 | grep -oE '[0-9]+\.[0-9]+')

cat <<EOF
IMPORTANT: Detected arxiv paper ${ARXIV_ID} in user message.
You MUST ask the user: "检测到 arxiv 论文 ${ARXIV_ID}，要我用 /read-paper 做结构化深度分析吗？"
Do NOT silently ignore this. Do NOT just summarize the link. Ask first, then run /read-paper if confirmed.
EOF
